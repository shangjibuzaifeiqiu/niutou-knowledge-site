---
import "katex/dist/katex.min.css";
import "../styles/global.css";
import BullMark from "../components/BullMark.astro";
import { site } from "../data/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = site.title,
  description = site.description,
} = Astro.props;
const pageTitle = title === site.title ? title : `${title} · ${site.title}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f5fbf7" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="返回首页">
        <BullMark />
        <span>{site.title}</span>
      </a>
      <nav aria-label="主导航">
        <a href="/library">知识库</a>
        <a href="/studio">知识工作台</a>
        <a href="/updates">更新日志</a>
        <a href="/about">关于</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <strong>{site.title}</strong>
        <p>从手写笔记生长出来的数学与物理知识库。</p>
      </div>
      <p>内容会持续校对，公式均可追溯到原笔记页码。</p>
    </footer>
    <script>
      document.documentElement.classList.add("is-ready");
      document.addEventListener("click", (event) => {
        const link = event.target instanceof Element ? event.target.closest("a") : null;
        if (!link || link.target || link.hasAttribute("download")) return;
        const url = new URL(link.href);
        if (url.origin !== window.location.origin || url.hash) return;
        document.documentElement.classList.add("is-leaving");
      });
    </script>
  </body>
</html>
