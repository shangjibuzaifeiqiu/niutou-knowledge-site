---
import BaseLayout from "../layouts/BaseLayout.astro";
import BullMark from "../components/BullMark.astro";
import NoteCard from "../components/NoteCard.astro";
import { site, subjects } from "../data/site";

const modules = import.meta.glob("./notes/*.md", { eager: true });
const notes = Object.entries(modules)
  .map(([path, mod]: any) => ({ href: path.replace("./", "/").replace(/\.md$/, ""), ...mod.frontmatter }))
  .sort((a, b) => String(b.updated).localeCompare(String(a.updated)))
const latestNotes = notes.slice(0, 3);
const courses = new Set(notes.map((note: any) => note.course)).size;
const chapters = new Set(notes.map((note: any) => `${note.course}/${note.chapter}`)).size;
const subjectCards = subjects.map((subject) => ({
  ...subject,
  count: notes.filter((note: any) => note.subject === subject.name).length,
  chapters: new Set(notes.filter((note: any) => note.subject === subject.name).map((note: any) => note.chapter)).size,
}));
---

<BaseLayout>
  <section class="home-hero">
    <div class="home-hero__copy">
      <span class="eyebrow"><i></i> PERSONAL KNOWLEDGE ATLAS</span>
      <h1>让手写笔记<br />长成<span>知识网络</span></h1>
      <p>{site.description} 每个知识点都能回到原笔记，每次整理都让结构更清楚一点。</p>
      <div class="home-hero__actions">
        <a class="button button--primary" href="/library">浏览知识库 <span>→</span></a>
        <a class="button button--soft" href="/studio">打开知识工作台</a>
      </div>
      <dl class="home-stats" aria-label="知识库统计">
        <div><dt>{notes.length}</dt><dd>知识点</dd></div>
        <div><dt>{courses}</dt><dd>门课程</dd></div>
        <div><dt>{chapters}</dt><dd>个章节</dd></div>
        <div><dt>100%</dt><dd>来源可追溯</dd></div>
      </dl>
    </div>

    <div class="knowledge-preview" aria-label="知识地图预览">
      <div class="knowledge-preview__bar">
        <div><span class="preview-dot"></span><strong>知识地图</strong></div>
        <span>实时整理中</span>
      </div>
      <div class="knowledge-preview__canvas">
        <svg viewBox="0 0 580 430" aria-hidden="true">
          <path d="M291 207C210 207 202 103 132 103M291 207C383 207 390 99 466 99M291 207C212 207 204 325 124 325M291 207C387 207 398 324 483 324" />
          <path class="preview-line--soft" d="M132 103C112 155 108 262 124 325M466 99C493 158 501 257 483 324" />
        </svg>
        <div class="preview-node preview-node--core"><span class="preview-bull"><BullMark /></span><strong>牛头的脑袋</strong><small>个人知识系统</small></div>
        <a class="preview-node preview-node--math" href="/library?q=数学分析"><i>∫</i><span><strong>数学分析</strong><small>定义 · 定理 · 计算</small></span></a>
        <a class="preview-node preview-node--mechanics" href="/library?q=分析力学"><i>δ</i><span><strong>分析力学</strong><small>约束 · 虚功 · 能量</small></span></a>
        <a class="preview-node preview-node--em" href="/library?q=电磁学"><i>E</i><span><strong>电磁学</strong><small>场 · 感应 · 波</small></span></a>
        <a class="preview-node preview-node--studio" href="/studio"><i>⌁</i><span><strong>关系工作台</strong><small>自由连接知识</small></span></a>
        <div class="preview-tip"><span>⌘</span> 选择节点继续探索</div>
      </div>
    </div>
  </section>

  <section class="home-section home-section--subjects">
    <div class="home-section__heading">
      <div><span class="eyebrow">EXPLORE BY SUBJECT</span><h2>从一门课开始探索</h2></div>
      <a href="/library">查看全部知识 <span>→</span></a>
    </div>
    <div class="home-subject-grid">
      {subjectCards.map((subject, index) => (
        <a class={`home-subject-card ${subject.tone}`} href={`/library?q=${encodeURIComponent(subject.name)}`}>
          <div class="home-subject-card__top"><span class="home-subject-card__index">0{index + 1}</span><span class="home-subject-card__icon">{subject.icon}</span></div>
          <div><h3>{subject.name}</h3><p>{subject.description}</p></div>
          <div class="home-subject-card__footer"><span>{subject.count} 个知识点 · {subject.chapters} 个章节</span><b>↗</b></div>
        </a>
      ))}
    </div>
  </section>

  <section class="home-workflow">
    <div class="home-workflow__copy">
      <span class="eyebrow">FROM PAPER TO NETWORK</span>
      <h2>不是把 PDF 搬上网，<br />而是把知识重新组织。</h2>
      <p>一份课程笔记会被拆成多个可检索的知识点，再按照学科、课程和章节归档。关系图负责补上目录无法表达的联系。</p>
      <a class="text-link" href="/about">查看整理与校对规则 <span>→</span></a>
    </div>
    <ol class="home-workflow__steps">
      <li><span>01</span><div><strong>转写</strong><p>逐页视觉检查手写内容，保留来源文件和页码。</p></div></li>
      <li><span>02</span><div><strong>拆分</strong><p>按概念、公式组和章节小节生成独立知识点。</p></div></li>
      <li><span>03</span><div><strong>连接</strong><p>用层级与关系图同时表达知识之间的结构。</p></div></li>
      <li><span>04</span><div><strong>复核</strong><p>修正与待复核内容都被明确记录，不覆盖来路。</p></div></li>
    </ol>
  </section>

  <section class="home-section home-section--latest">
    <div class="home-section__heading">
      <div><span class="eyebrow">RECENTLY ORGANIZED</span><h2>最近整理的知识</h2></div>
      <a href="/updates">查看更新记录 <span>→</span></a>
    </div>
    <div class="note-grid home-note-grid">
      {latestNotes.map((note: any) => <NoteCard {...note} />)}
    </div>
  </section>
</BaseLayout>
